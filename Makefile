check-prefixed-role-disks: ## Validate role-disk volume names match '<owner> - ' when .tart.disk.prefix.enforce=1
	if [[ "$(.tart.disk.prefix.enforce)" != "1" ]]; then
		: "Prefix enforcement disabled (.tart.disk.prefix.enforce=$(.tart.disk.prefix.enforce)); skipping role-disk prefix checks."
		exit 0
	fi
	owner_prefix="$(.tart.disk.prefix.owner) - "
	for img in $(.tart.disk.role.paths.effective); do
		if [[ ! -f "$$img" ]]; then
			echo "Missing role disk image: $$img" >&2
			exit 2
		fi
		json="$$(diskutil image attach -nomount -nobrowse -plist "$$img" | plutil -convert json -o - -- -)"
		detach_targets="$$(printf '%s\n' "$$json" | yq -p json -r '."system-entities"[] | select(has("dev-entry")) | ."dev-entry" | select(test("^(/dev/)?disk[0-9]+$$"))' | sed -E 's#^/dev/##' | awk '!seen[$$0]++ { print "/dev/" $$0 }')"
		matched=0
		while IFS= read -r vol_name; do
			[[ -z "$$vol_name" || "$$vol_name" == "null" ]] && continue
			if [[ "$$vol_name" == "$$owner_prefix"* ]]; then
				matched=1
				break
			fi
		done <<< "$$(printf '%s\n' "$$json" | yq -p json -r '."system-entities"[] | select((."filesystem-type" == "apfs") or (."content-hint" == "Apple_APFS_Volume")) | ."volume-name" // empty')"
		while IFS= read -r dev; do
			[[ -z "$$dev" ]] && continue
			diskutil detach "$$dev" >/dev/null 2>&1 || true
		done <<< "$$detach_targets"
		if [[ "$$matched" != "1" ]]; then
			echo "Role disk does not match required owner prefix '$$owner_prefix': $$img" >&2
			exit 1
		fi
	done

run: prepare-disks $(if $(filter 1,$(.tart.disk.prefix.enforce)),check-prefixed-role-disks,) ensure-root-disk-size $(.env.file) ## Run the built VM with all role disks attached
	declare -a extra_from_vm_args=()
	$(.tart.run.extra.disk.args.from-vm.shell)
	$(call .env.load)
	if [[ "$(.dry-run.tart.effective)" == "1" ]]; then
		printf 'DRY-RUN[tart]: %q ' TART_HOME="$${TART_HOME}" TART_HOME_FOREIGN="$${TART_HOME_FOREIGN}" $(.tart.cmd) run $(.tart.vm.name) $(strip $(.tart.run.disk.args) $(.tart.run.extra.disk.args) $(.tart.run.extra-args)) "$${extra_from_vm_args[@]}"
		echo
	else
		$(.tart.cmd) run $(.tart.vm.name) $(strip $(.tart.run.disk.args) $(.tart.run.extra.disk.args) $(.tart.run.extra-args)) "$${extra_from_vm_args[@]}"
	fi

console: prepare-disks $(if $(filter 1,$(.tart.disk.prefix.enforce)),check-prefixed-role-disks,) ensure-root-disk-size $(.env.file) ## Run VM with console troubleshooting defaults (Screen Sharing VNC + optional bridge/recovery)
	declare -a extra_from_vm_args=()
	$(.tart.run.extra.disk.args.from-vm.shell)
	$(call .env.load)
	if [[ "$(.dry-run.tart.effective)" == "1" ]]; then
		printf 'DRY-RUN[tart]: %q ' TART_HOME="$${TART_HOME}" TART_HOME_FOREIGN="$${TART_HOME_FOREIGN}" $(.tart.cmd) run $(.tart.vm.name) $(strip $(.tart.run.console.args) $(.tart.run.disk.args) $(.tart.run.extra.disk.args) $(.tart.run.extra-args)) "$${extra_from_vm_args[@]}"
		echo
	else
		$(.tart.cmd) run $(.tart.vm.name) $(strip $(.tart.run.console.args) $(.tart.run.disk.args) $(.tart.run.extra.disk.args) $(.tart.run.extra-args)) "$${extra_from_vm_args[@]}"
	fi

run-recovery-console: .tart.run.recovery=1
run-recovery-console: console ## Run VM in recovery mode with console troubleshooting defaults

run-script: prepare-disks $(if $(filter 1,$(.tart.disk.prefix.enforce)),check-prefixed-role-disks,) ensure-root-disk-size $(.env.file) ## Generate/update executable VM launcher script from current run settings
	declare -a extra_from_vm_args=()
	$(.tart.run.extra.disk.args.from-vm.shell)
	$(call .env.load)
	script_path="$(.tart.run.script.path)"
	mkdir -p "$$(dirname "$$script_path")"
	declare -a cmd_parts=(
		env
		"TART_HOME=$${TART_HOME}"
		"TART_HOME_FOREIGN=$${TART_HOME_FOREIGN}"
		"$(.tart.cmd)"
		run
		"$(.tart.vm.name)"
		$(.tart.run.script.args)
		"$${extra_from_vm_args[@]}"
	)
	{
		printf '%s\n' '#!/usr/bin/env -S bash -euxo pipefail'
		printf '\n'
		printf 'exec'
		for part in "$${cmd_parts[@]}"; do
			[[ -z "$$part" ]] && continue
			printf ' %q' "$$part"
		done
		printf '\n'
	} > "$$script_path"
	chmod 0755 "$$script_path" 2>/dev/null || true
	: "Generated VM launcher script: $$script_path"

hotfix-runtime-sync: run-script ## Sync active-stage runtime hotfix assets into versioned control folder (prunes stale stage dirs)
	root_dir="$(.hotfix.control.root)"
	stage="$(.hotfix.stage.effective)"
	stage_dir="$$root_dir/$$stage"
	script_path="$(.tart.run.script.path)"

	mkdir -p "$$root_dir" "$$stage_dir"

	for d in "$$root_dir"/*; do
		[[ -d "$$d" ]] || continue
		if [[ "$$d" != "$$stage_dir" ]]; then
			rm -rf "$$d"
		fi
	done

	cp -f "$$script_path" "$$stage_dir/$(.tart.vm.name).sh"

	printf '%s\n' "$$stage" > "$$root_dir/ACTIVE_STAGE"
	printf '%s\n' \
		"vm=$(.tart.vm.name)" \
		"stage=$$stage" \
		"generated_at=$$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
		"run_script=$$(basename "$$script_path")" \
		> "$$stage_dir/hotfix-assets.env"

	: "Synced active-stage hotfix assets to $$stage_dir"

info: $(.env.file) ## Show Tart VM details
	$(call .tart.run,list)
	$(call .tart.run,get $(.tart.vm.name))

disks-info: ## Show role disk files and sizes
	$(call .tart.disk.cmd.show-info,Data-Home-$(.data.home-user),$(.tart.disk.user.image-path.effective))
	$(call .tart.disk.cmd.show-info,Users:$(.data.home-user) Library Cache,$(.tart.disk.user-library.image-path.effective))
	$(call .tart.disk.cmd.show-info,Git Bare Store,$(.tart.disk.git-bare-store.image-path.effective))
	$(call .tart.disk.cmd.show-info,Git Store,$(.tart.disk.git-store.image-path.effective))
	$(call .tart.disk.cmd.show-info,Nix Store,$(.tart.disk.nix-store.image-path.effective))
	$(call .tart.disk.cmd.show-info,Users:$(.data.home-user) Build Chains Cache,$(.tart.disk.user-build-chains-cache.image-path.effective))
	$(call .tart.disk.cmd.show-info,Users:$(.data.home-user) VM Images,$(.tart.disk.vm-images.image-path.effective))

rename-disk-volume: ## Rename APFS volume inside one ASIF image (.tart.disk.path required; .tart.disk.path.rename optional override; use .dry-run.disk=1 to avoid rename writes)
	if [[ -z "$(strip $(.tart.disk.path.effective))" ]]; then
		echo "Missing required .tart.disk.path (or .tart.disk.path.rename)" >&2
		exit 2
	fi
	prefix="$(.tart.disk.name.effective)"
	image_path="$(.tart.disk.path.effective)"
	$(.tart.disk.cmd.rename-volume)

rename-disk-volumes: rename-disk-volumes-check $(.tart.vm.name.paths.rename-targets) ## Rename all ASIF APFS volumes from .tart.vm.name with '<vm> - ' prefix by default

rename-foreign-role-disk-volumes: ## Rename APFS labels in foreign role disks with '<vm> - ' ownership prefix (space-safe)
	disks_dir="$(.tart.home.foreign)/disks/$(.tart.vm.name)"
	if [[ ! -d "$$disks_dir" ]]; then
		echo "No foreign disk directory found: $$disks_dir" >&2
		exit 2
	fi
	found=0
	while IFS= read -r -d '' img; do
		found=1
		$(MAKE) rename-disk-volume \
			.tart.disk.path.rename="$$img" \
			.tart.disk.name="$(.tart.vm.name) - " \
			.dry-run="$(.dry-run)" \
			.dry-run.disk="$(.dry-run.disk.effective)"
	done < <(find "$$disks_dir" -maxdepth 1 -type f -name '*.asif' -print0 | sort -z)
	if [[ "$$found" != "1" ]]; then
		echo "No foreign .asif images found in $$disks_dir" >&2
		exit 2
	fi

rename-disk-attached-volumes: $(.tart.disk.volume-devs.rename-targets) ## Rename explicit attached APFS volume devices from .tart.disk.volume-devs for one .tart.disk.path
	if [[ -z "$(strip $(.tart.disk.path.effective))" ]]; then
		echo "Missing required .tart.disk.path (or .tart.disk.path.rename)" >&2
		exit 2
	fi
	if [[ -z "$(strip $(.tart.disk.volume-devs))" ]]; then
		echo "Missing required .tart.disk.volume-devs (space-separated disk identifiers, e.g. disk7s1 /dev/disk7s2)" >&2
		exit 2
	fi

rename-disk-volumes-check:
	if [[ -z "$(strip $(.tart.vm.name))" ]]; then
		echo "Missing required .tart.vm.name" >&2
		exit 2
	fi
	if [[ -z "$(strip $(.tart.vm.name.paths))" ]]; then
		echo "No ASIF images found under $(.tart.disk.rename.home)/disks/$(.tart.vm.name)" >&2
		exit 2
	fi

%~rename: FORCE ## Internal: rename APFS volume for one ASIF path (dynamic dependency pattern)
	prefix="$(.tart.disk.name.effective)"
	image_path="$(patsubst %~rename,%,$@)"
	$(.tart.disk.cmd.rename-volume)

%~rename-volume: .tart.disk.volume-dev=$(patsubst %~rename-volume,%,$@)
%~rename-volume: FORCE ## Internal: rename one explicit attached APFS volume device for .tart.disk.path
	prefix="$(.tart.disk.name.effective)"
	image_path="$(.tart.disk.path.effective)"
	$(.tart.disk.cmd.rename-volume)

apfs-ownership-policy: ## Apply APFS ownership policy (default disable for portability); supports .apfs.ownership.* vars
	if [[ ! -f "$(.apfs.ownership.script)" ]]; then
		echo "Missing script: $(.apfs.ownership.script)" >&2
		exit 2
	fi
	args=( --ownership-mode "$(.apfs.ownership.mode)" )
	if [[ "$(.dry-run.apfs.ownership.effective)" == "1" ]]; then args+=( --dry-run ); fi
	if [[ "$(.apfs.ownership.all-roles)" == "1" ]]; then args+=( --all-roles ); fi
	if [[ "$(.apfs.ownership.include-system-mounts)" == "1" ]]; then args+=( --include-system-mounts ); fi
	if [[ -n "$(strip $(.apfs.ownership.images))" ]]; then
		for img in $(.apfs.ownership.images); do
			args+=( --image "$$img" )
		done
	fi
	bash "$(.apfs.ownership.script)" "$${args[@]}"

rm-runtime: validate-tart $(.env.file) $(.tart.vm.names.rm-runtime-targets) ## Stop runtime and remove VM artifact/state for each name in .tart.vm.names

%~rm-runtime: FORCE
	vm_name="$${@%~rm-runtime}"
	$(.tart.cmd.rm-runtime-one)

rm-runtime-one: validate-tart $(.env.file) ## Internal: stop runtime and remove VM artifact/state for .tart.vm.name
	vm_name="$(.tart.vm.name)"
	$(.tart.cmd.rm-runtime-one)

rm-role-disks: $(.tart.vm.names.rm-role-disks-targets) ## Remove role disks for each name in .tart.vm.names (non-interactive)

%~rm-role-disks: FORCE
	vm_name="$${@%~rm-role-disks}"
	$(.tart.cmd.rm-role-disks-one)

rm-role-disks-one: ## Internal: remove role disks for .tart.vm.name (non-interactive)
	vm_name="$(.tart.vm.name)"
	$(.tart.cmd.rm-role-disks-one)

rm-owned-role-disks: ## Remove only owned role disk images resolved by .tart.disk.role.paths.effective
	$(.tart.cmd.rm-owned-role-disks)

rm: ## Remove runtime/artifact for .tart.rm.vm.name; remove only owned role disks unless .skip includes 'disks'
	$(MAKE) rm-runtime-one .tart.vm.name="$(.tart.rm.vm.name)"
	if [[ " $(.skip) " == *" disks "* ]]; then
		: "Skipping role disk removal because .skip includes 'disks'."
		: "VM $(.tart.rm.vm.name): removed runtime/artifact; skipped owned role disks (.skip includes 'disks')."
	elif [[ "$(.tart.run.extra-disks.add-renamed)" == "1" && "$(.rm.skip-owned-disks-when-add-renamed)" == "1" ]]; then
		: "Skipping role disk removal because renamed-disk mode is enabled (.tart.run.extra-disks.add-renamed=1)."
		: "Set .rm.skip-owned-disks-when-add-renamed=0 to allow owned-role-disk deletion explicitly."
		: "VM $(.tart.rm.vm.name): removed runtime/artifact; preserved owned role disks by safety guard."
	else
		$(MAKE) rm-owned-role-disks .tart.vm.name="$(.tart.rm.vm.name)"
		: "VM $(.tart.rm.vm.name): removed runtime/artifact and owned role disks only."
	fi

refresh-console: rm build console ## Fresh credential-debug flow: wipe VM+disks, rebuild, launch with console

refresh: validate-tart $(.env.file) ## Rebuild from existing VM into candidate VM (.tart.update.from-vm -> .tart.update.to-vm)
	if [[ "$(.tart.update.from-vm)" == "$(.tart.update.to-vm)" && "$(.tart.update.tart-home)" == "$(.tart.home)" ]]; then
		echo "Refusing refresh with identical source/target VM names." >&2
		echo "Use a distinct .tart.update.to-vm (e.g. nikopol-refresh) or a dedicated .tart.update.tart-home." >&2
		exit 2
	fi
	$(call .env.load)
	if ! $(.tart.cmd) get "$(.tart.update.from-vm)" >/dev/null 2>&1; then
		echo "Missing source VM to refresh from: $(.tart.update.from-vm)" >&2
		exit 2
	fi
	source_vm_state="$$( $(.tart.cmd) list | awk -v vm="$(.tart.update.from-vm)" '$$1=="local" && $$2==vm {print $$NF; found=1; exit} END { if (!found) print "" }' )"
	if [[ "$$source_vm_state" == "running" ]]; then
		echo "Refusing refresh while source VM is running: $(.tart.update.from-vm)" >&2
		echo "Stop it first (e.g. tart stop $(.tart.update.from-vm))." >&2
		exit 2
	fi
	base_ref="$(.tart.update.from-vm)"
	if [[ "$(.tart.update.tart-home)" != "$(.tart.home)" && "$(.tart.update.link-source-vm)" == "1" ]]; then
		refresh_vms_dir="$(.tart.update.tart-home)/vms"
		mkdir -p "$$refresh_vms_dir"
		src_vm_dir="$(.tart.home)/vms/$(.tart.update.from-vm)"
		if [[ ! -e "$$src_vm_dir" ]]; then
			echo "Missing source VM directory for symlink: $$src_vm_dir" >&2
			exit 2
		fi
		alias_path="$$refresh_vms_dir/$(.tart.update.source-vm-alias)"
		if [[ "$(.dry-run.tart.effective)" == "1" ]]; then
			echo "DRY-RUN[tart]: would symlink source VM $$src_vm_dir -> $$alias_path"
		else
			ln -sfn "$$src_vm_dir" "$$alias_path"
		fi
		base_ref="$(.tart.update.source-vm-alias)"
	fi
	if [[ "$(.tart.update.link-role-disks)" == "1" ]]; then
		dst_dir="$(.tart.update.tart-home)/disks/$(.tart.update.to-vm)"
		mkdir -p "$$dst_dir"
		for base in user-data.asif user-library.asif git-bare-store.asif git-store.asif nix-store.asif build-chains-cache.asif vm-images.asif; do
			src="$(.tart.home)/disks/$(.tart.update.from-vm)/$$base"
			dst="$$dst_dir/$$base"
			if [[ -e "$$src" ]]; then
				if [[ "$$(readlink "$$dst" 2>/dev/null || true)" != "$$src" ]]; then
					if [[ "$(.dry-run.disk.effective)" == "1" ]]; then
						echo "DRY-RUN[disk]: would symlink $$src -> $$dst"
					else
						ln -sfn "$$src" "$$dst"
					fi
				fi
			fi
		done
	fi
	$(MAKE) build-image TART_HOME="$(.tart.update.tart-home)" .template="$(.template.customize)" .tart.base.ref="$$base_ref" .tart.vm.name="$(.tart.update.to-vm)" .tart.disk.source-vm="$(.tart.update.to-vm)" .provision.profile="$(.tart.update.profile)" .macos.relax-session-tweaks="$(.tart.update.relax-session-tweaks)"

promote: validate-tart $(.env.file) ## Replace .tart.update.from-vm with .tart.update.to-vm by clone promotion
	if [[ "$(.tart.update.from-vm)" == "$(.tart.update.to-vm)" ]]; then
		echo "Refusing promotion with identical source/target VM names." >&2
		exit 2
	fi
	source_home="$(.tart.update.tart-home)"
	target_home="$(.tart.home)"
	promote_source_name="$(.tart.update.to-vm)"
	import_name="$(.tart.update.source-vm-alias)-promote"
	import_path="$$target_home/vms/$$import_name"
	refresh_vm_dir="$$source_home/vms/$(.tart.update.to-vm)"
	if [[ "$(.dry-run.tart.effective)" == "1" ]]; then
		if [[ "$$source_home" != "$$target_home" ]]; then
			echo "DRY-RUN[tart]: would move refreshed VM $$refresh_vm_dir -> $$import_path"
			echo "DRY-RUN[tart]: would stop/delete $(.tart.update.from-vm) in $$target_home then clone $$import_name -> $(.tart.update.from-vm)"
			echo "DRY-RUN[tart]: would remove temporary imported VM $$import_path"
		else
			echo "DRY-RUN[tart]: would stop/delete $(.tart.update.from-vm) then clone $(.tart.update.to-vm) -> $(.tart.update.from-vm)"
		fi
		exit 0
	fi
	if ! TART_HOME="$$source_home" $(.tart.cmd) get "$(.tart.update.to-vm)" >/dev/null 2>&1; then
		echo "Missing refreshed VM to promote: $(.tart.update.to-vm)" >&2
		exit 2
	fi
	if [[ "$$source_home" != "$$target_home" ]]; then
		if [[ ! -e "$$refresh_vm_dir" ]]; then
			echo "Missing refreshed VM directory for promotion: $$refresh_vm_dir" >&2
			exit 2
		fi
		mkdir -p "$$target_home/vms"
		rm -rf "$$import_path"
		if ! mv "$$refresh_vm_dir" "$$import_path"; then
			echo "Failed to move refreshed VM for promotion: $$refresh_vm_dir -> $$import_path" >&2
			exit 2
		fi
		promote_source_name="$$import_name"
		cleanup_import() {
			rm -rf "$$import_path" >/dev/null 2>&1 || true
		}
		trap cleanup_import EXIT
	fi
	TART_HOME="$$target_home" $(.tart.cmd) stop "$(.tart.update.from-vm)" >/dev/null 2>&1 || true
	if TART_HOME="$$target_home" $(.tart.cmd) get "$(.tart.update.from-vm)" >/dev/null 2>&1; then
		TART_HOME="$$target_home" $(.tart.cmd) delete "$(.tart.update.from-vm)"
	fi
	TART_HOME="$$target_home" $(.tart.cmd) clone "$$promote_source_name" "$(.tart.update.from-vm)"
	if [[ "$$source_home" != "$$target_home" ]]; then
		cleanup_import
		trap - EXIT
	fi
	: "Promoted $(.tart.update.to-vm) -> $(.tart.update.from-vm)"

shell-fmt: ## Format shell scripts if shfmt is available
	if command -v shfmt >/dev/null 2>&1; then
		shfmt -w scripts/*.sh
	else
		: "shfmt not found, skipping."
	fi

shell-check: ## Lint shell scripts if shellcheck is available
	if command -v shellcheck >/dev/null 2>&1; then
		shellcheck scripts/*.sh
	else
		: "shellcheck not found, skipping."
	fi

fmt: shell-fmt ## Alias for shell-fmt

FORCE:
