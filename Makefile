SHELL := bash
.SHELLFLAGS := -euxo pipefail -c
.ONESHELL:
.SILENT:
.DEFAULT_GOAL := help

# Tooling
TART_HOME ?= .tart
TART_HOME_FOREIGN ?= .tart.foreign
.tart.home ?= $(strip $(TART_HOME))
.tart.home.foreign ?= $(strip $(TART_HOME_FOREIGN))
.packer.cmd ?= packer
.tart.cmd ?= tart
.env.file ?= .env
-include $(.env.file)

TART_WORKING_VM ?= nikopol
TART_EXTRA_DISKS_ADD_RENAMED ?= 0
TART_EXTRA_DISKS_RENAMED_FROM_VM ?= nikopol

define .env.load
set -a
. "$(.env.file)"
TART_HOME="$(.tart.home)"
TART_HOME_FOREIGN="$(.tart.home.foreign)"
set +a
endef

define .env.file.content
# Generated by Make. Edit Make variables instead.
# Flox manifest owns TART_HOME and TART_HOME_FOREIGN.
TART_WORKING_VM=$(.tart.vm.name)
TART_EXTRA_DISKS_ADD_RENAMED=$(TART_EXTRA_DISKS_ADD_RENAMED)
TART_EXTRA_DISKS_RENAMED_FROM_VM=$(TART_EXTRA_DISKS_RENAMED_FROM_VM)
TART_ATTACH_FOREIGN_RENAMED=$(TART_ATTACH_FOREIGN_RENAMED)
endef

define .packer.run
$(call .env.load)
if [[ "$(.dry-run.packer.effective)" == "1" ]]; then
	echo "DRY-RUN[packer]: $(.packer.cmd) $(1)"
else
	packer_cmdline="$(strip $(1))"
	if [[ "$$packer_cmdline" == build* ]]; then
		packer_log="$(.tart.home)/vms/$(.tart.vm.name).packer.log"
		mkdir -p "$(.tart.home)/vms"
		set +e
		$(.packer.cmd) $(1) 2>&1 | tee "$$packer_log"
		packer_ec="$${PIPESTATUS[0]}"
		set -e
		exit "$$packer_ec"
	else
		$(.packer.cmd) $(1)
	fi
fi
endef

define .tart.run
$(call .env.load)
if [[ "$(.dry-run.tart.effective)" == "1" ]]; then
	echo "DRY-RUN[tart]: TART_HOME=\"$${TART_HOME}\" TART_HOME_FOREIGN=\"$${TART_HOME_FOREIGN}\" $(.tart.cmd) $(1)"
else
	$(.tart.cmd) $(1)
fi
endef

.tart.base.ref ?= ghcr.io/cirruslabs/macos-tahoe-vanilla:latest
.tart.clone.force ?= 0
.tart.disk.recreate ?= 0
.tart.disk.blank.fs ?= APFS

.tart.disk.cmd.ensure-parent = if [[ "$(.dry-run.disk.effective)" == "1" ]]; then : "DRY-RUN[disk]: mkdir -p $(dir $1)"; else mkdir -p "$(dir $1)"; fi
.tart.disk.cmd.prepare-image = if [[ "$(.dry-run.disk.effective)" == "1" ]]; then if [[ "$(.tart.disk.recreate)" == "1" && -f "$2" ]]; then : "DRY-RUN[disk]: would recreate $1 disk: $2"; fi; if [[ -f "$2" ]]; then : "DRY-RUN[disk]: would reuse existing $1 disk: $2"; else : "DRY-RUN[disk]: would create $1 disk: $2 ($3G, fs $(.tart.disk.blank.fs))"; fi; else if [[ "$(.tart.disk.recreate)" == "1" && -f "$2" ]]; then : "Recreating $1 disk: $2"; rm -f "$2"; fi; if [[ -f "$2" ]]; then : "Reusing existing $1 disk: $2"; else diskutil image create blank --format ASIF --size $3G --fs "$(.tart.disk.blank.fs)" --volumeName "$1" "$2"; fi; fi
.tart.disk.cmd.show-info = : "$1: $2"; ls -lh "$2" 2>/dev/null || true

